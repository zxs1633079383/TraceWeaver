node_modules/
dist/
*.tsbuildinfo
.DS_Store
*.log
.env

# IDE
.idea/

# Daemon runtime data (socket, pid, WAL, event log, entity store)
.traceweaver/
# But track the project config (Jaeger endpoint, watch dirs, notify rules)
!.traceweaver/config.yaml

# Stale compiled output that landed in src/ before outDir was fixed
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# lockfile (managed separately)
package-lock.json
.worktrees/

# Documentation (internal-only, not committed)
# Only README.md and QUICKSTART.md are tracked
**/*.md
!README.md
!README.zh-CN.md
!QUICKSTART.md
!QUICKSTART.zh-CN.md
!docs/harness/**/*.md
